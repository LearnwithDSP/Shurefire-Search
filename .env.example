# =======================================================
# SHUREFIRE SYSTEM CONFIGURATION (ENVIRONMENT TEMPLATE)
# =======================================================
# DO NOT put your real keys in this file. Copy this file,
# rename it to `.env`, and put your real keys there instead.

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted locally/live
APP_URL="http://localhost:5173"

# Standard Supabase Credentials
SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# Vite-Specific Environment Mappings (Required for React build outputs)
VITE_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"